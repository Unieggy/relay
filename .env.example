# Baton — environment configuration
# Copy to `.env` and adjust. All values are optional; sane defaults apply.

# --- server ---------------------------------------------------------------
# Port the local control server binds to (loopback only).
PORT=4000
# Origin of the dashboard UI allowed to talk to the server.
WEB_URL=http://localhost:3000
# development | test | production
NODE_ENV=development

# --- handoff behavior -----------------------------------------------------
# Automatic handoff when a limit is detected (rate-limit / context pressure).
# 1/true = on (the bundled demo relies on it). 0/false = manual: the active
# agent keeps the baton until the user clicks Switch.
RELAY_AUTO_HANDOFF=1

# Use deterministic fake agents instead of real provider CLIs.
# 1/true = safe offline demo (no provider auth). 0/false = real claude + codex.
RELAY_FAKE_AGENTS=1

# --- persistence (optional) ----------------------------------------------
# Set to enable durable, refresh-surviving event timelines + latest packet.
# Unset → an in-memory store with the same interface is used.
# REDIS_URL=redis://localhost:6379
